# Chandra OCR Settings
CHANDRA_BATCH_SIZE=1
CHANDRA_QUANTIZATION=4bit
CHANDRA_MAX_TOKENS=2048
CHANDRA_DEVICE=cuda
CHANDRA_TIMEOUT=120
CHANDRA_MODEL_ID=datalab-to/chandra-ocr-2

# Database
DB_URL=sqlite:///./data/medical_services.db

# Processing
PARALLEL_PROCESSING=false
MAX_WORKERS=2
RETRY_ATTEMPTS=3
